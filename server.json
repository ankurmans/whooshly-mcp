{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ankurmans/whooshly-mcp",
  "description": "Create short links, QR codes, UTM templates, and vCards from your AI assistant.",
  "repository": {
    "url": "https://github.com/ankurmans/whooshly-mcp",
    "source": "github"
  },
  "version": "1.0.1",
  "websiteUrl": "https://whooshly.co",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://app.whooshly.co/api/mcp"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "whooshly-mcp",
      "version": "1.0.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "WHOOSHLY_TOKEN",
          "description": "Agent token minted at https://app.whooshly.co (Agents).",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ]
}
